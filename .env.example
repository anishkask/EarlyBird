# Personal Information
YOUR_NAME=Your full name
YOUR_EMAIL=Your email address (e.g., your@email.com)
YOUR_SCHOOL=Your school/university name (e.g., Temple University)
YOUR_LINKEDIN=Your LinkedIn profile URL or username
YOUR_GITHUB=Your GitHub profile URL or username
YOUR_PORTFOLIO=Your portfolio website URL

# API Keys for Job Board & Email Scraping
ANTHROPIC_API_KEY=sk-ant-xxx                    # Required: Claude API for email drafting
APOLLO_API_KEY=                                 # Optional: Apollo.io for founder contact enrichment
                                               # Get from: https://app.apollo.io/settings/integrations

# Crunchbase API Key (optional - for dynamic recently-funded startup discovery)
# Leave blank to use hardcoded fallback company list
CRUNCHBASE_API_KEY=
