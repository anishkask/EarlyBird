# Copy to .env and fill in. Never commit .env.

# --- Required ---
ANTHROPIC_API_KEY=          # Claude API key; used for contact research and outreach drafting

# --- Identity (personalizes outreach drafts; all optional) ---
YOUR_NAME=
YOUR_EMAIL=
YOUR_LINKEDIN=
YOUR_PORTFOLIO=
MY_BACKGROUND=              # One-line summary of skills/experience used in outreach drafts

# --- Optional ---
CRUNCHBASE_API_KEY=         # Only used by funding_pull.py (dynamic company discovery)
ALLOWED_HOSTS=              # api.py: comma-separated trusted hosts for deployment (default allows localhost)
PORT=                       # api.py: server port (default 8000)
