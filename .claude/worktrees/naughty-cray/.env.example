# Personal Information
YOUR_NAME=Your full name (used in outreach emails)
YOUR_EMAIL=Your email address (e.g., your@email.com)
YOUR_SCHOOL=Your school/university name (e.g., Temple University)
YOUR_LINKEDIN=Your LinkedIn profile URL or username
YOUR_GITHUB=Your GitHub profile URL or username
YOUR_PORTFOLIO=Your portfolio website URL

# Professional Background (used in outreach drafting)
MY_BACKGROUND=Brief description of your skills and experience (used in AI-drafted outreach)

# Anthropic API Key (required for Claude AI outreach drafting)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Crunchbase API Key (optional - for dynamic recently-funded startup discovery)
# Free API key: https://www.crunchbase.com/api
# Leave blank to use hardcoded fallback company list
CRUNCHBASE_API_KEY=

# Email delay configuration (in seconds)
# Prevents spam detection by adding random delays between emails
EMAIL_DELAY_MIN=120
EMAIL_DELAY_MAX=300

# ── Cold Outreach module ─────────────────────────────────────────────────────

# Apollo.io API key for CEO/founder contact enrichment
# Free tier: https://www.apollo.io  (50 searches/day on free plan)
APOLLO_API_KEY=

# Toggle the entire cold outreach stage (true/false)
COLD_OUTREACH_ENABLED=true

# Max new companies to process per daily run (Apollo free tier = 50 req/day)
COLD_OUTREACH_MAX_PER_DAY=10

# Create Gmail drafts automatically for each new contact (true/false)
# Requires gmail.compose OAuth scope — delete token.json and re-run once to re-authorize
CREATE_GMAIL_DRAFTS=true

# Employee count filter — skip companies outside this range
COLD_OUTREACH_MIN_EMPLOYEES=1
COLD_OUTREACH_MAX_EMPLOYEES=75

# Comma-separated list of VC portfolio URLs to scrape
# Leave blank to use the built-in Philadelphia-area VC defaults
COLD_OUTREACH_VC_SOURCES=
